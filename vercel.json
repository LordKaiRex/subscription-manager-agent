{
  "version": 2,
  "rewrites": [
    { "source": "/auth/(.*)", "destination": "/api/server" },
    { "source": "/subscriptions(.*)", "destination": "/api/server" },
    { "source": "/jobs(.*)", "destination": "/api/server" },
    { "source": "/agent(.*)", "destination": "/api/server" },
    { "source": "/trigger", "destination": "/api/server" },
    { "source": "/setup-keys", "destination": "/api/server" },
    { "source": "/debug", "destination": "/api/server" }
  ]
}
