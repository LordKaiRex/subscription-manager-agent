{
  "version": 2,
  "builds": [
    { "src": "api/server.ts", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/auth/(.*)", "dest": "/api/server.ts" },
    { "src": "/subscriptions(.*)", "dest": "/api/server.ts" },
    { "src": "/jobs(.*)", "dest": "/api/server.ts" },
    { "src": "/agent(.*)", "dest": "/api/server.ts" },
    { "src": "/trigger", "dest": "/api/server.ts" },
    { "src": "/setup-keys", "dest": "/api/server.ts" },
    { "src": "/debug", "dest": "/api/server.ts" },
    { "src": "/public/(.*)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
